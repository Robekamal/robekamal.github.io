---
layout: null
permalink: /search.json
---

[
  {% for post in site.posts %}

    {% assign author_data = site.data.authors[post.author] %}

    {
      "title": {{ post.title | default: "بدون عنوان" | jsonify }},

      "excerpt": {{ post.description
        | default: post.excerpt
        | strip_html
        | strip_newlines
        | normalize_whitespace
        | truncate: 220
        | jsonify
      }},

      "content": {{ post.content
        | strip_html
        | strip_newlines
        | normalize_whitespace
        | jsonify
      }},

      "categories": [
        {% if post.categories %}
          {% for category in post.categories %}
            {{ category | jsonify }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        {% elsif post.category %}
          {{ post.category | jsonify }}
        {% elsif post.category_label %}
          {{ post.category_label | jsonify }}
        {% endif %}
      ],

      "tags": [
        {% if post.tags %}
          {% for tag in post.tags %}
            {{ tag | jsonify }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        {% endif %}
      ],

      "author": {% if author_data and author_data.name %}
        {{ author_data.name | jsonify }}
      {% elsif post.author %}
        {{ post.author | jsonify }}
      {% else %}
        ""
      {% endif %},

      "author_avatar": {% if author_data and author_data.avatar %}
        {{ author_data.avatar | relative_url | jsonify }}
      {% elsif post.author_avatar %}
        {{ post.author_avatar | relative_url | jsonify }}
      {% else %}
        {{ '/assets/images/authors/default.jpg' | relative_url | jsonify }}
      {% endif %},

      "image": {% if post.image %}
        {{ post.image | relative_url | jsonify }}
      {% elsif post.thumbnail %}
        {{ post.thumbnail | relative_url | jsonify }}
      {% else %}
        ""
      {% endif %},

      "url": {{ post.url | relative_url | jsonify }},

      "date": {% if post.date_fa %}
        {{ post.date_fa | jsonify }}
      {% else %}
        {{ post.date | date: "%Y/%m/%d" | jsonify }}
      {% endif %},

      "date_iso": {{ post.date | date_to_xmlschema | jsonify }}
    }{% unless forloop.last %},{% endunless %}

  {% endfor %}
]
