---
layout: null
permalink: /search.json
---

[
  {% for post in site.posts %}
    {
      "title": {{ post.title | jsonify }},
      "description": {{ post.description | default: post.excerpt | strip_html | strip_newlines | truncate: 180 | jsonify }},
      "category": {{ post.category_label | default: post.category | default: post.categories.first | jsonify }},
      "tags": {{ post.tags | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "date": {{ post.date_fa | default: post.date | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
